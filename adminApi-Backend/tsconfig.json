{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "outDir": "./_buildOutput",
    "rootDir": "./src",     // Wurzelverzeichnis der Quellcodedateien
    // "baseUrl": "./src",     // Basisverzeichnis für absolute Importe
    "sourceMap": true,
    "verbatimModuleSyntax": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
  },
  "include": ["src"]
}
